# Configuração do Atlas — copie para .env e preencha com seus valores
# NUNCA commite .env no repositório (ver .gitignore)

# Telegram
# Token do seu bot do Telegram (criar em https://t.me/botfather)
TELEGRAM_TOKEN=seu_token_aqui

# Seu ID do Telegram (envie /start para @userinfobot para descobrir)
ATLAS_ALLOWED_USER_ID=seu_id_aqui

# Banco de dados (opcional)
# ATLAS_DB_PATH=atlas.sqlite

# Diretório de rotinas (opcional)
# ATLAS_ROUTINES_DIR=routines

# Timeout de polling (opcional, em segundos)
# ATLAS_POLL_TIMEOUT=30
